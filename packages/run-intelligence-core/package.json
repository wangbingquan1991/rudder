{
  "name": "@rudderhq/run-intelligence-core",
  "version": "0.2.4",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/Undertone0809/rudder",
  "bugs": {
    "url": "https://github.com/Undertone0809/rudder/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Undertone0809/rudder",
    "directory": "packages/run-intelligence-core"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@rudderhq/agent-runtime-claude-local": "workspace:*",
    "@rudderhq/agent-runtime-codex-local": "workspace:*",
    "@rudderhq/agent-runtime-cursor-local": "workspace:*",
    "@rudderhq/agent-runtime-gemini-local": "workspace:*",
    "@rudderhq/agent-runtime-openclaw-gateway": "workspace:*",
    "@rudderhq/agent-runtime-opencode-local": "workspace:*",
    "@rudderhq/agent-runtime-pi-local": "workspace:*",
    "@rudderhq/agent-runtime-utils": "workspace:*",
    "@rudderhq/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
