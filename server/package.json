{
  "name": "@rudderhq/server",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/Undertone0809/rudder",
  "bugs": {
    "url": "https://github.com/Undertone0809/rudder/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Undertone0809/rudder",
    "directory": "server"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "resources",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "cross-env RUDDER_MIGRATION_PROMPT=never RUDDER_MIGRATION_AUTO_APPLY=true tsx watch --ignore ../ui/node_modules --ignore ../ui/.vite --ignore ../ui/dist src/index.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "node ../scripts/build-tsc-copy-assets.mjs --copy src/onboarding-assets dist/onboarding-assets",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @rudderhq/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@langfuse/client": "^5.1.0",
    "@langfuse/otel": "^5.1.0",
    "@langfuse/tracing": "^5.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "@rudderhq/agent-runtime-claude-local": "workspace:*",
    "@rudderhq/agent-runtime-codex-local": "workspace:*",
    "@rudderhq/agent-runtime-cursor-local": "workspace:*",
    "@rudderhq/agent-runtime-gemini-local": "workspace:*",
    "@rudderhq/agent-runtime-openclaw-gateway": "workspace:*",
    "@rudderhq/agent-runtime-opencode-local": "workspace:*",
    "@rudderhq/agent-runtime-pi-local": "workspace:*",
    "@rudderhq/agent-runtime-utils": "workspace:*",
    "@rudderhq/db": "workspace:*",
    "@rudderhq/plugin-sdk": "workspace:*",
    "@rudderhq/run-intelligence-core": "workspace:*",
    "@rudderhq/shared": "workspace:*",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.4.18",
    "chokidar": "^4.0.3",
    "detect-port": "^2.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.4",
    "embedded-postgres": "18.1.0-beta.16",
    "express": "^5.2.1",
    "hermes-paperclip-adapter": "0.1.1",
    "jsdom": "^28.1.0",
    "multer": "^2.1.1",
    "open": "^11.0.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsdom": "^28.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
